---
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default {...Astro.props} />

<biel-button
  project="mtzvzmjwbg"
  header-title="Tweenly Assistant"
  button-position="bottom-right"
  modal-position="sidebar-right"
  button-style="dark">
  Ask AI
</biel-button>

